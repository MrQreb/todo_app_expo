{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "paths": {
      "@src/*": ["./src/*"],
      "@components/*": ["./src/components/*"],
      "@config/*": ["./src/config/*"],
      "@db/*": ["./src/db/*"],
      "@queries/*": ["./src/queries/*"],
      "@assets/*": ["./src/assets/*"],
      "@migrations/*": ["./drizzle/*"]
    }
  },
  "include": ["**/*.ts", "**/*.tsx", ".expo/types/**/*.ts", "expo-env.d.ts"]
}
